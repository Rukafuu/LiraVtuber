{
    "_titulo": "Lira - Config local (Ollama + Edge TTS + Whisper)",
    "_nota": "Copie para src/config/config.json para ajustes locais. Nunca coloque chaves aqui.",
    "user_role_name": "reskyume",
    "assistant_role_name": "Lira",
    "LLM_PROVIDER": "ollama",
    "LLM_TEMPERATURE": 0.85,
    "LLM_PROVIDERS": {
        "ollama": {
            "modelo": "qwen2.5:7b",
            "modelo_chat": "qwen2.5:7b",
            "modelo_vision": "llava",
            "base_url": "http://localhost:11434/v1"
        },
        "groq": {
            "modelo": "llama-3.1-8b-instant",
            "modelo_chat": "llama-3.1-8b-instant",
            "modelo_vision": "meta-llama/llama-4-scout-17b-16e-instruct",
            "modelo_web": "groq/compound-mini"
        }
    },
    "CHAT": {
        "LLM_PROVIDER": "ollama",
        "LLM_MODEL": "qwen2.5:7b",
        "LLM_TEMPERATURE": 0.85,
        "usa_mesmo_prompt_terminal": false,
        "response_mode": "adaptive",
        "auto_route_media": false,
        "max_output_tokens_normal": 4096,
        "markdown_enabled": true,
        "media_model": "gemini-2.5-flash",
        "max_output_tokens_media": 8192
    },
    "TTS_PROVIDER": "edge",
    "TTS_SETTINGS": {
        "edge": {
            "voice": "pt-BR-GiovannaNeural",
            "rate": "+10%",
            "pitch": "+2Hz",
            "volume": "+0%"
        },
        "elevenlabs": {
            "voice_id": "UqJBeKrjGrdsP4JSZ7w6",
            "voice": "UqJBeKrjGrdsP4JSZ7w6",
            "model_id": "eleven_flash_v2_5",
            "rate": 1.1,
            "pitch": 0.0,
            "stability": 0.5,
            "similarity_boost": 0.75,
            "style": 0.0,
            "speaker_boost": true
        },
        "google": {
            "voice": "pt-BR-Neural2-C",
            "language_code": "pt-BR",
            "rate": 1.25,
            "pitch": 1.4
        },
        "azure": {
            "voice": "pt-BR-ThalitaNeural",
            "rate": "+0%",
            "pitch": "0Hz"
        },
        "openai": {
            "model": "gpt-4o-mini-tts",
            "voice": "coral",
            "rate": 1.0,
            "pitch": 0.0,
            "style": "natural e clara"
        }
    },
    "TTS_ATIVO": true,
    "STT_ATIVO": true,
    "STT_MODEL": "large-v3",
    "STT_LANGUAGE": "pt",
    "MIC_DEVICE_INDEX": 9,
    "TAXA_AMOSTRAGEM": 44100,
    "VISAO_ATIVA": false,
    "VISAO_MONITOR": 1,
    "VTUBESTUDIO_ATIVO": false,
    "VTUBE_STUDIO": {
        "host": "localhost",
        "port": 8001,
        "emotion_map": {
            "HAPPY": "happy",
            "SAD": "sad",
            "ANGRY": "angry",
            "SHY": "shy",
            "SURPRISED": "surprised",
            "SMUG": "smug",
            "NEUTRAL": "neutral",
            "LOVE": "love"
        }
    },
    "GUI": {
        "accent_color": "#f472b6",
        "bg_opacity": 1.0,
        "ptt_key": "F2",
        "ptt_enabled": false,
        "stop_hotkey_enabled": true,
        "stop_hotkey": "F8"
    },
    "PC_CONTROL": {
        "brave_path": ""
    },
    "MEDIA": {
        "enabled": false,
        "queue": {
            "max_concurrent_jobs": 1
        }
    },
    "LIRA_INBOX_ROOT": "",
    "LIRA_INBOX_MODEL": "gemini-2.5-flash",
    "Modo_discord": false,
    "precione_para_falar": false,
    "TECLA_PTT": "F2",
    "STT_DEVICE": "auto"
}