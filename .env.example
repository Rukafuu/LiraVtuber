# --- API Keys ---
# OpenRouter
OPENROUTER_API_KEY=sua_chave_aqui

# Groq
GROQ_API_KEY=sua_chave_aqui

# OpenAI
OPENAI_API_KEY=sua_chave_aqui

# ElevenLabs
ELEVENLABS_API_KEY=sua_chave_aqui

# Google Gemini (Vertex / AI Studio)
GEMINI_API_KEY=sua_chave_aqui
GOOGLE_CLOUD_PROJECT=seu_projeto_google_cloud
GOOGLE_CLOUD_LOCATION=us-central1

# Tavily Web Search (Obrigatorio para Tools)
TAVILY_API_KEY=sua_chave_aqui

# --- Azure TTS (Opcional - Legado) ---
AZURE_SPEECH_KEY=sua_chave_aqui
AZURE_REGION=brazilsouth

# --- TTS ---
# Google/Edge/Azure/OpenAI/ElevenLabs usam TTS_PROVIDER e TTS_SETTINGS no config.json.
# O OpenAI TTS usa OPENAI_API_KEY, voz multi-lingue e pitch por estilo.
# O ElevenLabs usa ELEVENLABS_API_KEY e aceita voice_id/model_id manualmente na GUI.
